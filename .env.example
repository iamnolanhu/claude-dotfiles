# Claude Code Global Environment Variables
# Copy to ~/.claude/.env and fill in values
# NEVER commit the actual .env file to git
# Permissions should be 600: chmod 600 ~/.claude/.env

# === API Keys for Projects ===
# KAGGLE_KEY=
# ELEVENLABS_API_KEY=
# AGENTMAIL_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# === Self-Hosted Services ===
# CRAWL4AI_URL=https://crawl.example.com
# CRAWL4AI_TOKEN=

# === Add more API keys below ===
